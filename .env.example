# AWS Configuration
# Get these from your AWS account
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# AWS Bedrock Configuration
# Claude model ID - update to your preferred model
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MAX_TOKENS=2000
BEDROCK_ANTHROPIC_VERSION=bedrock-2024-06-04
# Optional: Bedrock Inference Profile ARN
BEDROCK_INFERENCE_PROFILE_ARN=your_inference_profile_arn_here

# iOS Configuration
# Device simulator name to target
IOS_DEVICE_NAME=iPhone 16
# Bundle ID of your test app
IOS_BUNDLE_ID=com.example.testapp
# Simulator UDID (get from `xcrun simctl list devices`)
IOS_SIMULATOR_UDID=your_simulator_udid_here

# Android Configuration
# Android device ID (e.g., emulator-5554)
ANDROID_DEVICE_ID=emulator-5554
# App package name
ANDROID_APP_PACKAGE=com.example.app
# App activity
ANDROID_APP_ACTIVITY=.MainActivity

# Automation Configuration
# Enable debug logging
DEBUG=false
# Timeout for Appium operations (seconds)
AUTOMATION_TIMEOUT=30
# Number of retries for failed operations
MAX_RETRIES=3
# Directory for screenshots
SCREENSHOTS_DIR=./screenshots
# Appium server URL
APPIUM_URL=http://localhost:4723
